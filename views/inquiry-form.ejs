<%- include('partials/layout-start') %>

<section class="block-card narrow">
  <h2>문의 작성</h2>
  <p class="muted-label">문의 내용은 작성자와 어드민만 확인 가능합니다.</p>
  <form method="post" action="/inquiry/new" enctype="multipart/form-data" class="form-grid">
    <label>제목
      <input type="text" name="title" required />
    </label>

    <label>내용
      <textarea name="content" rows="6" required></textarea>
    </label>

    <label>이미지 (선택)
      <input type="file" name="image" accept="image/*" />
    </label>

    <button type="submit" class="cta-main">문의 등록</button>
  </form>
</section>

<%- include('partials/layout-end') %>
