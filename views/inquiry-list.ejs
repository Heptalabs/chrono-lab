<%- include('partials/layout-start') %>

<section class="block-card">
  <div class="section-head">
    <h2>문의</h2>
    <% if (ctx.currentUser) { %>
      <a href="/inquiry/new" class="chip dark">문의 작성</a>
    <% } else { %>
      <a href="/login" class="chip">로그인 후 작성</a>
    <% } %>
  </div>

  <ul class="line-list">
    <% if (inquiries.length === 0) { %>
      <li>등록된 문의가 없습니다.</li>
    <% } %>

    <% inquiries.forEach((item) => { %>
      <li>
        <a href="/inquiry/<%= item.id %>"><%= item.title %></a>
        <span>
          <%= item.writer %>
          <% if (item.reply_content) { %>
            / 답변완료
          <% } else { %>
            / 답변대기
          <% } %>
        </span>
      </li>
    <% }) %>
  </ul>
</section>

<%- include('partials/layout-end') %>
