<%- include('partials/layout-start') %>
<% const isEn = ctx.lang === 'en'; %>

<section class="block-card">
  <div class="section-head">
    <h2><%= isEn ? 'Inquiry' : '문의' %></h2>
    <% if (ctx.currentUser) { %>
      <a href="/inquiry/new" class="chip dark"><%= isEn ? 'Write inquiry' : '문의 작성' %></a>
    <% } else { %>
      <a href="/login" class="chip"><%= isEn ? 'Login to write' : '로그인 후 작성' %></a>
    <% } %>
  </div>

  <ul class="line-list">
    <% if (inquiries.length === 0) { %>
      <li><%= isEn ? 'No inquiries found.' : '등록된 문의가 없습니다.' %></li>
    <% } %>

    <% inquiries.forEach((item) => { %>
      <li>
        <a href="/inquiry/<%= item.id %>"><%= item.title %></a>
        <span>
          <%= item.writer %>
          <% if (item.reply_content) { %>
            / <%= isEn ? 'Replied' : '답변완료' %>
          <% } else { %>
            / <%= isEn ? 'Pending' : '답변대기' %>
          <% } %>
        </span>
      </li>
    <% }) %>
  </ul>
</section>

<%- include('partials/layout-end') %>
