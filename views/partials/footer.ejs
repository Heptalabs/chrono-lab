<footer class="site-footer">
  <div class="footer-grid">
    <section class="footer-card">
      <h4>Brand</h4>
      <% if (ctx.settings.footerLogoPath) { %>
        <img src="<%= ctx.settings.footerLogoPath %>" alt="footer logo" class="footer-logo" />
      <% } else { %>
        <div class="footer-logo-fallback">Chrono Lab</div>
      <% } %>
      <p class="footer-small">Simple. Clean. Trusted watch shopping.</p>
    </section>

    <section class="footer-card">
      <h4>사이트 정보</h4>
      <p class="footer-small"><%= ctx.settings.businessInfo %></p>
      <p class="footer-small"><%= ctx.settings.contactInfo %></p>
      <p class="footer-small"><%= ctx.settings.bankAccountInfo %></p>
    </section>

    <section class="footer-card">
      <h4>공지사항</h4>
      <% if (ctx.footerNotices.length === 0) { %>
        <p class="footer-small">등록된 공지가 없습니다.</p>
      <% } %>
      <ul class="footer-links">
        <% ctx.footerNotices.forEach((notice) => { %>
          <li><a href="/notice/<%= notice.id %>"><%= notice.title %></a></li>
        <% }) %>
      </ul>
    </section>

    <section class="footer-card">
      <h4>집계</h4>
      <p class="footer-small"><%= ctx.t('footerVisitorsToday') %> : <strong><%= ctx.metrics.visitToday %></strong></p>
      <p class="footer-small"><%= ctx.t('footerVisitorsTotal') %> : <strong><%= ctx.metrics.visitTotal %></strong></p>
      <p class="footer-small"><%= ctx.t('footerPostsToday') %> : <strong><%= ctx.metrics.postToday %></strong></p>
      <p class="footer-small"><%= ctx.t('footerPostsTotal') %> : <strong><%= ctx.metrics.postTotal %></strong></p>
    </section>
  </div>
</footer>
