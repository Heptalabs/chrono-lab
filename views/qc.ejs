<%- include('partials/layout-start') %>

<section class="block-card">
  <div class="section-head">
    <h2>QC</h2>
    <span class="muted-label">구매번호로 검색</span>
  </div>

  <form method="get" action="/qc" class="inline-search">
    <input type="text" name="orderNo" value="<%= orderNo %>" placeholder="예: CL-20260326-AB12CD" />
    <button type="submit" class="chip dark">검색</button>
  </form>

  <div class="qc-grid">
    <% if (items.length === 0) { %>
      <p>등록된 QC 이미지가 없습니다.</p>
    <% } %>
    <% items.forEach((item) => { %>
      <article class="qc-card">
        <img src="<%= item.image_path %>" alt="qc image" />
        <strong>구매번호: <%= item.order_no %></strong>
        <p><%= item.note || '-' %></p>
        <small><%= item.created_at.slice(0, 10) %></small>
      </article>
    <% }) %>
  </div>
</section>

<%- include('partials/layout-end') %>
